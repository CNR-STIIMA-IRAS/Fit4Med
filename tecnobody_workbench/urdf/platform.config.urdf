<!-- SmartGravity3D manipulator -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="tecnobody">

    <!-- Import urdf file -->
    <xacro:include filename="$(find tecnobody_workbench)/urdf/platform_complete.urdf" />

    <!-- Import ros2_control description -->
    <xacro:include filename="$(find tecnobody_workbench)/urdf/ros2_control/platform_complete.ros2_control.urdf" />

</robot>