
import numpy as np
from scipy.interpolate import CubicSpline

def make_cart_trj3_from_points(P, yaml_out="out.yaml"):
    P = np.array(P, dtype=float)

    if P.shape[0] < 2:
        raise ValueError("At least 2 waypoints required")
    if not np.allclose(P[0], [0,0,0]):
        raise ValueError("First waypoint must be [0,0,0]")

    nGo = 30
    nRet = 30
    Ttot = 3.0
    Tgo = Ttot / 2.0

    d = np.linalg.norm(np.diff(P, axis=0), axis=1)
    u_nodes = np.concatenate(([0], np.cumsum(d)))
    u_nodes = u_nodes / u_nodes[-1]

    cs_x = CubicSpline(u_nodes, P[:,0])
    cs_y = CubicSpline(u_nodes, P[:,1])
    cs_z = CubicSpline(u_nodes, P[:,2])

    u_dense = np.linspace(0,1,2000)
    Pd = np.vstack((cs_x(u_dense), cs_y(u_dense), cs_z(u_dense))).T
    dseg = np.linalg.norm(np.diff(Pd, axis=0), axis=1)
    L = np.concatenate(([0], np.cumsum(dseg)))
    L = L / L[-1]

    L_unique, idx = np.unique(L, return_index=True)
    u_unique = u_dense[idx]

    fGo = np.linspace(0,1,nGo)
    fRet = np.linspace(1,0,nRet+1)[1:]
    fAll = np.concatenate((fGo, fRet))

    uAll = np.interp(fAll, L_unique, u_unique)
    cart_positions = np.vstack((cs_x(uAll), cs_y(uAll), cs_z(uAll))).T

    def inv_sigma(s):
        return (Tgo/np.pi) * np.arccos(np.clip(1 - 2*s, -1, 1))

    tGo = inv_sigma(fGo)
    prRet = np.linspace(0,1,nRet+1)[1:]
    tRet = Tgo + inv_sigma(prRet)
    tAll = np.concatenate((tGo, tRet))
    tAll[-1] = Ttot

    dseg2 = np.linalg.norm(np.diff(cart_positions, axis=0), axis=1)
    L2 = np.concatenate(([0], np.cumsum(dseg2)))
    v = np.gradient(L2, tAll)
    max_velocity = np.max(v)

    end_config = P[-1]

    with open(yaml_out, "w") as f:
        f.write("a_movement_definition:\n")
        f.write("  begin_config:\n")
        f.write("  - - 0.0\n    - 0.0\n    - 0.0\n")
        f.write("  begin_joint_config:\n")
        f.write("  - - 0.0\n    - 0.0\n    - 0.0\n")
        f.write("  end_config:\n")
        f.write(f"  - - {end_config[0]:.15g}\n")
        f.write(f"    - {end_config[1]:.15g}\n")
        f.write(f"    - {end_config[2]:.15g}\n")
        f.write("  max_velocity:\n")
        f.write(f"  - {max_velocity:.15g}\n")
        f.write("  side:\n  - 2\n")
        f.write("  total_time:\n")
        f.write(f"  - {Ttot}\n")
        f.write("  type:\n  - 2\n")
        f.write("  vel_profile:\n  - 2\n")
        f.write("cart_trj3:\n")
        f.write("  cart_positions:\n")
        for p in cart_positions:
            f.write(f"  - - {p[0]:.15g}\n")
            f.write(f"    - {p[1]:.15g}\n")
            f.write(f"    - {p[2]:.15g}\n")
        f.write("  joint_names:\n")
        f.write("  - joint_1\n  - joint_2\n  - joint_3\n")
        f.write("  time_from_start:\n")
        for t in tAll:
            f.write(f"  - - {t:.15g}\n")

    return yaml_out
